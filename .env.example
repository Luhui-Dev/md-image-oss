# ───────────────────────────────────────────────────────────────────
# Aliyun OSS configuration
# Copy this file to .env and fill in your own values.
# Never commit your real .env file — it's in .gitignore.
# ───────────────────────────────────────────────────────────────────

# Required ─────────────────────────────────────────────────────────
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret

# Region endpoint, e.g.
#   https://oss-cn-hangzhou.aliyuncs.com
#   https://oss-cn-shanghai.aliyuncs.com
#   https://oss-cn-beijing.aliyuncs.com
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

OSS_BUCKET=your-bucket-name

# Optional ─────────────────────────────────────────────────────────

# Path prefix prepended to every uploaded object (no leading/trailing slash).
# Useful for keeping your bucket tidy: e.g. images uploaded by this tool
# will live under markdown/ in the bucket.
OSS_PREFIX=markdown

# If you've configured a CDN / custom domain on OSS, the public URLs in the
# rewritten Markdown will use it instead of the default
# <bucket>.<endpoint> URL. Either http(s) form or bare host works.
#   OSS_CUSTOM_DOMAIN=cdn.example.com
#   OSS_CUSTOM_DOMAIN=https://cdn.example.com
OSS_CUSTOM_DOMAIN=
